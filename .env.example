BOT_TOKEN=your_telegram_bot_token
APP_TIMEZONE=Asia/Yekaterinburg

# Optional: path to SQLite database.
# Default is reminders.db.
DB_PATH=reminders.db

# Optional: chat_id where the bot sends periodic healthcheck messages.
# Leave empty to disable healthcheck.
HEALTHCHECK_CHAT_ID=

# Optional: healthcheck interval in minutes.
# Default is 360 minutes.
HEALTHCHECK_INTERVAL_MINUTES=360

# Optional: comma-separated origins allowed to call FastAPI from browser/TMA.
# Leave empty to disable CORS middleware.
# Example: https://example.com,https://tma.example.com
API_ALLOWED_ORIGINS=

# Optional: public HTTPS URL for Telegram Mini App.
# Example: https://example.com/tma/
TMA_URL=